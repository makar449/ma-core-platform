{
  "name": "@ma-core/web",
  "version": "2.5.0",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "NEXT_TELEMETRY_DISABLED=1 NEXT_PRIVATE_BUILD_WORKER=1 next build",
    "start": "next start -p 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "e2e": "playwright test -c playwright.config.ts",
    "visual:qa": "playwright test -c playwright.config.ts --grep @visual",
    "e2e:mock": "E2E_MOCK_API=true playwright test -c playwright.config.ts --project=chromium",
    "build:github-pages": "NEXT_PUBLIC_DEPLOY_TARGET=github-pages NEXT_PUBLIC_DEMO_MODE=true NEXT_TELEMETRY_DISABLED=1 NEXT_PRIVATE_BUILD_WORKER=1 next build && touch out/.nojekyll"
  },
  "dependencies": {
    "@ma-core/shared": "workspace:*",
    "framer-motion": "^12.0.6",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
