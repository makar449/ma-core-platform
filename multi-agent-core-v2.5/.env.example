NODE_ENV=development
API_PORT=4100
NEXT_PUBLIC_API_URL=http://localhost:4100
NEXT_PUBLIC_API_TIMEOUT_MS=12000
POSTGRES_URL=postgres://ma_core:ma_core_password@localhost:5433/ma_core
REDIS_URL=redis://localhost:6380
VAULT_MASTER_KEY_BASE64=MDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDAwMDA=

# Vault provider modes: env, file, http.
VAULT_KEY_PROVIDER=env
# VAULT_KEY_FILE=/run/secrets/ma_core_vault_key.json
# VAULT_KEY_PROVIDER_URL=https://vault.internal/v1/ma-core/data-key
# VAULT_KEY_PROVIDER_BEARER_TOKEN=replace-with-provider-token
VAULT_KEY_PROVIDER_TIMEOUT_MS=5000
VAULT_KEY_VERSION=v1
JWT_AUTH_SECRET_BASE64=MTExMTExMTExMTExMTExMTExMTExMTExMTExMTExMTE=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
AUTH_REGISTRATION_MODE=invite
AUTH_REGISTRATION_TOKEN=replace-with-a-random-32-byte-invite-token
COOKIE_DOMAIN=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_MS=12000
LLM_MAX_RETRIES=2
EMBEDDING_PROVIDER=deterministic
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=64
BINANCE_BASE_URL=https://api.binance.com
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BINANCE_WS_URL=wss://stream.binance.com:9443/stream
BINANCE_FUTURES_WS_URL=wss://fstream.binance.com/stream
BYBIT_BASE_URL=https://api.bybit.com
BYBIT_LINEAR_WS_URL=wss://stream.bybit.com/v5/public/linear
EXCHANGE_REST_TIMEOUT_MS=7000
EXCHANGE_REST_RATE_LIMIT_PER_MINUTE=240
X_BEARER_TOKEN=
X_CRYPTO_AUTHOR_IDS=
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_ACCESS_TOKEN=
YOUTUBE_CRYPTO_CHANNEL_IDS=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ma-core-v2.0/1.0
WEB_ORIGIN=http://localhost:3000
MARKET_PAIRS=BINANCE:BTC/USDT,BYBIT:BTC/USDT

# Part 2 execution and autonomous risk guardrails
EXECUTION_DEFAULT_MODE=PAPER
EXECUTION_RISK_PER_TRADE_FRACTION=0.01
EXECUTION_MIN_NOTIONAL_USDT=10
EXECUTION_QUANTITY_STEP=0.001
DAILY_MAX_DRAWDOWN_RATIO=0.05
DAILY_PROFIT_CAP_RATIO=0.15
POSITION_TIMEOUT_WARNING_MINUTES=165
POSITION_FORCE_CLOSE_MINUTES=180

# v2.1 execution safety
EXECUTION_MIN_CONFIDENCE=0.72
EXECUTION_REQUIRE_SYMBOL_RULES_FOR_LIVE=true
EXECUTION_REQUIRE_PRIVATE_STREAM_FOR_LIVE=true
EXECUTION_MAX_ORDERBOOK_AGE_MS=3000
EXECUTION_MAX_SPREAD_BPS=25
EXECUTION_MAX_DAILY_TRADES=20
EXECUTION_MAX_OPEN_POSITIONS=3

# GitHub Pages static demo mode. Used only for the no-backend shareable demo link.
NEXT_PUBLIC_DEPLOY_TARGET=self-hosted
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_GITHUB_PAGES_REPO=
